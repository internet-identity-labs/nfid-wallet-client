  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "analyze": "source-map-explorer",
    "analyze:nfid-frontend": "yarn analyze 'dist/apps/nfid-frontend/static/js/*.js'",
    "build": "echo '💀 DONT REMOVE THIS 💀'",
    "dedupe:deps": "npx yarn-deduplicate yarn.lock",
    "test:e2e:frontend": "./scripts/run-e2e-frontend.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "yarn nx run-many --target=lint --all",
    "report": "node_modules/.bin/allure generate apps/nfid-frontend-e2e/src/reporter/desktop/allure-results --clean -o apps/nfid-frontend-e2e/src/reporter/desktop/allure-report && node_modules/.bin/allure open apps/nfid-frontend-e2e/src/reporter/desktop/allure-report",
    "reportMobile": "node_modules/.bin/allure generate apps/nfid-frontend-e2e/src/reporter/mobile/allure-results --clean -o apps/nfid-frontend-e2e/src/reporter/mobile/allure-report && node_modules/.bin/allure open apps/nfid-frontend-e2e/src/reporter/mobile/allure-report",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md,yml,yaml,html}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
