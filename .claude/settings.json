{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-tool-use.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use.js"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(yarn nx lint*)",
      "Bash(yarn nx test*)",
      "Bash(yarn nx build*)",
      "Bash(yarn nx serve*)",
      "Bash(yarn nx typecheck*)",
      "Bash(yarn nx storybook*)",
      "Bash(yarn format*)",
      "Bash(yarn format:check*)",
      "Bash(tsc --noEmit*)",
      "Bash(yarn prettier*)"
    ]
  }
}
