{
  "name": "nfid-frontend-e2e",
  "type": "module",
  "scripts": {
    "test:e2e": "npx wdio run wdio.conf.ts",
    "test:mobile-e2e": "npx wdio run wdio-mobile.conf.ts",
    "generate-cucumber-html-report": "ts-node ./src/reporter/index.ts",
    "allure-report": "allure generate allure-results --clean && allure open",
    "reportMobile": "allure generate src/reporter/mobile/allure-results --clean -o src/reporter/mobile/allure-report && allure open src/reporter/mobile/allure-report",
    "clean": "rm -rf allure-results allure-report"
  },
  "repository": "git@github.com:internet-identity-labs/nfid-wallet-client.git",
